---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
---

<div class="grid grid-cols-1 gap-4 md:grid-cols-2 md:gap-5 xl:grid-cols-3">
  {posts.map((post) => (
    <article
      class="group h-full rounded-[26px] border border-outline/14 bg-surface/92 text-on-surface transition-[border-color,background-color] duration-200 ease-out hover:border-outline/22 hover:bg-surface"
    >
      <a href={`/blog/${post.id}/`} class="flex h-full min-h-64 flex-col gap-5 p-5 md:p-6">
        <div class="flex flex-col gap-3">
          <h2 class="text-3xl font-medium leading-[1.08] tracking-tight text-balance md:text-[2rem]">
            {post.data.title}
          </h2>
          <time class="text-sm font-medium text-on-surface-variant">
            {formatDate(post.data.date)}
          </time>
        </div>

        {post.data.description && (
          <p class="max-w-[34ch] text-base leading-8 text-on-surface-variant">
            {post.data.description}
          </p>
        )}

        {post.data.tags && post.data.tags.length > 0 && (
          <div class="mt-auto flex flex-wrap gap-2 pt-2">
            {post.data.tags.map((tag) => (
              <span
                class="rounded-full border border-outline/10 bg-background px-3 py-1 text-xs font-medium tracking-[0.01em] text-secondary"
              >
                {tag}
              </span>
            ))}
          </div>
        )}
      </a>
    </article>
  ))}
</div>
