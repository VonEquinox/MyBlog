---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<figure class:list={['not-prose', 'von-diagram', className]}>
  <svg
    viewBox="0 0 900 420"
    role="img"
    aria-labelledby="von-title von-desc"
    xmlns="http://www.w3.org/2000/svg"
  >
    <title id="von-title">冯·诺依曼架构：数据/控制/反馈信号示意</title>
    <desc id="von-desc">
      输入、输出、存储器、运算器与控制器之间的数据通路（实线）、控制信号（蓝色线）与状态反馈（虚线）。
    </desc>

    <defs>
      <marker id="arrow-data" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="var(--md-sys-color-on-surface)" opacity="0.78" />
      </marker>
      <marker id="arrow-control" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="var(--md-sys-color-primary)" opacity="0.95" />
      </marker>
      <marker id="arrow-status" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="var(--md-sys-color-outline)" opacity="0.9" />
      </marker>

      <filter id="soft-shadow" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="0" dy="10" stdDeviation="14" flood-color="rgba(0,0,0,0.14)" />
      </filter>
    </defs>

    <!-- Background card -->
    <rect x="18" y="18" width="864" height="384" rx="26" fill="color-mix(in srgb, var(--md-sys-color-surface) 94%, transparent)" stroke="color-mix(in srgb, var(--md-sys-color-outline) 18%, transparent)" />

    <!-- Nodes -->
    <g filter="url(#soft-shadow)">
      <rect class="node" x="64" y="168" width="170" height="86" rx="18" />
      <rect class="node" x="365" y="168" width="170" height="86" rx="18" />
      <rect class="node" x="640" y="92" width="200" height="86" rx="18" />
      <rect class="node" x="640" y="252" width="200" height="86" rx="18" />
      <rect class="node node--cu" x="350" y="36" width="200" height="74" rx="18" />
    </g>

    <!-- Labels -->
    <g class="label">
      <text x="149" y="206" text-anchor="middle">输入设备</text>
      <text x="450" y="206" text-anchor="middle">运算器（ALU）</text>
      <text x="740" y="130" text-anchor="middle">存储器（Memory）</text>
      <text x="740" y="290" text-anchor="middle">输出设备</text>
      <text x="450" y="78" text-anchor="middle">控制器（CU）</text>
    </g>

    <!-- Data path (solid) -->
    <g class="data">
      <!-- Input -> ALU -->
      <path d="M 234 211 L 365 211" marker-end="url(#arrow-data)" />

      <!-- ALU <-> Memory (two parallel arrows) -->
      <path d="M 535 198 L 640 146" marker-end="url(#arrow-data)" />
      <path d="M 640 162 L 535 222" marker-end="url(#arrow-data)" />

      <!-- ALU -> Output -->
      <path d="M 535 224 L 640 274" marker-end="url(#arrow-data)" />
    </g>

    <!-- Control signals (blue) -->
    <g class="control">
      <path d="M 450 110 L 450 168" marker-end="url(#arrow-control)" />
      <path d="M 520 98 L 670 92" marker-end="url(#arrow-control)" />
      <path d="M 520 102 L 670 252" marker-end="url(#arrow-control)" />
      <path d="M 380 98 L 234 168" marker-end="url(#arrow-control)" />
    </g>

    <!-- Status / feedback (dashed) -->
    <g class="status">
      <path d="M 450 168 L 420 110" marker-end="url(#arrow-status)" />
      <path d="M 740 178 L 510 110" marker-end="url(#arrow-status)" />
      <path d="M 740 252 L 520 110" marker-end="url(#arrow-status)" />
      <path d="M 149 168 L 350 110" marker-end="url(#arrow-status)" />
    </g>

    <!-- Legend -->
    <g class="legend">
      <rect x="58" y="310" width="298" height="78" rx="18" />
      <g transform="translate(76 332)">
        <path class="legend-data" d="M 0 0 L 52 0" marker-end="url(#arrow-data)" />
        <text x="68" y="5">数据（实线）</text>
      </g>
      <g transform="translate(76 356)">
        <path class="legend-control" d="M 0 0 L 52 0" marker-end="url(#arrow-control)" />
        <text x="68" y="5">控制（蓝色线）</text>
      </g>
      <g transform="translate(76 380)">
        <path class="legend-status" d="M 0 0 L 52 0" marker-end="url(#arrow-status)" />
        <text x="68" y="5">反馈/状态（虚线）</text>
      </g>
    </g>
  </svg>

  <figcaption class="von-diagram__caption">
    冯·诺依曼架构中五大部件的连接示意：数据通路（实线）、控制信号（蓝色线）与状态反馈（虚线）。
  </figcaption>
</figure>

<style>
  .von-diagram {
    margin: 1.75rem 0 2.15rem;
  }

  .von-diagram svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .node {
    fill: color-mix(in srgb, var(--md-sys-color-background) 92%, transparent);
    stroke: color-mix(in srgb, var(--md-sys-color-outline) 22%, transparent);
    stroke-width: 1.2;
  }

  .node--cu {
    fill: color-mix(in srgb, var(--md-sys-color-primary-container) 42%, var(--md-sys-color-background));
  }

  .label text {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 20px;
    font-weight: 650;
    fill: var(--md-sys-color-on-surface);
    dominant-baseline: middle;
  }

  .data path {
    fill: none;
    stroke: var(--md-sys-color-on-surface);
    stroke-opacity: 0.78;
    stroke-width: 3.4;
    stroke-linecap: round;
  }

  .control path {
    fill: none;
    stroke: var(--md-sys-color-primary);
    stroke-opacity: 0.95;
    stroke-width: 3.2;
    stroke-linecap: round;
  }

  .status path {
    fill: none;
    stroke: var(--md-sys-color-outline);
    stroke-opacity: 0.9;
    stroke-width: 2.6;
    stroke-linecap: round;
    stroke-dasharray: 8 7;
  }

  .legend rect {
    fill: color-mix(in srgb, var(--md-sys-color-surface-variant) 24%, transparent);
    stroke: color-mix(in srgb, var(--md-sys-color-outline) 18%, transparent);
  }

  .legend text {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 16px;
    font-weight: 560;
    fill: var(--md-sys-color-on-surface-variant);
    dominant-baseline: middle;
  }

  .legend-data,
  .legend-control,
  .legend-status {
    fill: none;
    stroke-linecap: round;
    stroke-width: 3.2;
  }

  .legend-data {
    stroke: var(--md-sys-color-on-surface);
    stroke-opacity: 0.78;
  }

  .legend-control {
    stroke: var(--md-sys-color-primary);
    stroke-opacity: 0.95;
  }

  .legend-status {
    stroke: var(--md-sys-color-outline);
    stroke-opacity: 0.9;
    stroke-dasharray: 8 7;
    stroke-width: 2.6;
  }

  .von-diagram__caption {
    margin-top: 0.85rem;
    color: var(--md-sys-color-on-surface-variant);
    font-size: 0.95rem;
    line-height: 1.55;
  }
</style>

