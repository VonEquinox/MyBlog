---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<figure class:list={['not-prose', 'von-diagram', className]}>
  <svg
    viewBox="0 0 900 500"
    role="img"
    aria-labelledby="von-title von-desc"
    xmlns="http://www.w3.org/2000/svg"
  >
    <title id="von-title">冯·诺依曼架构：数据/控制/反馈信号示意</title>
    <desc id="von-desc">
      输入、输出、存储器、运算器与控制器之间的数据通路（实线）、控制信号（蓝色线）与状态反馈（虚线）。
    </desc>

    <defs>
      <marker id="arrow-data" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="var(--md-sys-color-on-surface)" opacity="0.78" />
      </marker>
      <marker id="arrow-control" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="var(--md-sys-color-primary)" opacity="0.95" />
      </marker>
      <marker id="arrow-status" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="var(--md-sys-color-outline)" opacity="0.9" />
      </marker>

      <filter id="soft-shadow" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="0" dy="10" stdDeviation="14" flood-color="rgba(0,0,0,0.14)" />
      </filter>
    </defs>

    <!-- Background card -->
    <rect x="18" y="18" width="864" height="464" rx="26" fill="color-mix(in srgb, var(--md-sys-color-surface) 94%, transparent)" stroke="color-mix(in srgb, var(--md-sys-color-outline) 18%, transparent)" />

    <!-- Nodes -->
    <g filter="url(#soft-shadow)">
      <rect class="node" x="70" y="290" width="190" height="80" rx="18" />

      <rect class="node node--cpu" x="330" y="180" width="240" height="200" rx="22" />
      <rect class="node node--cu" x="350" y="200" width="200" height="70" rx="18" />
      <rect class="node" x="350" y="290" width="200" height="80" rx="18" />

      <rect class="node" x="340" y="60" width="220" height="80" rx="18" />
      <rect class="node" x="640" y="290" width="190" height="80" rx="18" />
    </g>

    <!-- Labels -->
    <g class="label">
      <text x="165" y="330" text-anchor="middle">输入设备</text>

      <text x="450" y="235" text-anchor="middle">控制器（CU）</text>
      <text x="450" y="330" text-anchor="middle">运算器（ALU）</text>

      <text x="450" y="100" text-anchor="middle">存储器（Memory）</text>
      <text x="735" y="330" text-anchor="middle">输出设备</text>
    </g>

    <!-- Data path (solid) -->
    <g class="data">
      <!-- Input -> ALU -->
      <path d="M 260 330 L 350 330" marker-end="url(#arrow-data)" />

      <!-- Memory <-> ALU -->
      <path d="M 450 140 L 450 290" marker-start="url(#arrow-data)" marker-end="url(#arrow-data)" />

      <!-- ALU -> Output -->
      <path d="M 550 330 L 640 330" marker-end="url(#arrow-data)" />
    </g>

    <!-- Control signals (blue) -->
    <g class="control">
      <!-- CU -> Memory -->
      <path d="M 500 200 L 500 140" marker-end="url(#arrow-control)" />

      <!-- CU -> Input -->
      <path d="M 350 235 L 350 170 L 165 170 L 165 290" marker-end="url(#arrow-control)" />

      <!-- CU -> Output -->
      <path d="M 550 235 L 550 170 L 735 170 L 735 290" marker-end="url(#arrow-control)" />
    </g>

    <!-- Status / feedback (dashed) -->
    <g class="status">
      <!-- Memory -> CU -->
      <path d="M 400 140 L 400 200" marker-end="url(#arrow-status)" />

      <!-- Input -> CU -->
      <path d="M 165 370 L 165 400 L 380 400 L 380 270" marker-end="url(#arrow-status)" />

      <!-- Output -> CU -->
      <path d="M 735 370 L 735 400 L 520 400 L 520 270" marker-end="url(#arrow-status)" />
    </g>

    <!-- Legend -->
    <g class="legend">
      <rect x="58" y="412" width="310" height="70" rx="18" />
      <g transform="translate(76 432)">
        <path class="legend-data" d="M 0 0 L 52 0" marker-end="url(#arrow-data)" />
        <text x="68" y="5">数据（实线）</text>
      </g>
      <g transform="translate(76 454)">
        <path class="legend-control" d="M 0 0 L 52 0" marker-end="url(#arrow-control)" />
        <text x="68" y="5">控制（蓝色线）</text>
      </g>
      <g transform="translate(76 476)">
        <path class="legend-status" d="M 0 0 L 52 0" marker-end="url(#arrow-status)" />
        <text x="68" y="5">反馈/状态（虚线）</text>
      </g>
    </g>
  </svg>

  <figcaption class="von-diagram__caption">
    冯·诺依曼架构中五大部件的连接示意：数据通路（实线）、控制信号（蓝色线）与状态反馈（虚线）。
  </figcaption>
</figure>

<style>
  .von-diagram {
    margin: 1.75rem 0 2.15rem;
  }

  .von-diagram svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .node {
    fill: color-mix(in srgb, var(--md-sys-color-background) 92%, transparent);
    stroke: color-mix(in srgb, var(--md-sys-color-outline) 22%, transparent);
    stroke-width: 1.2;
  }

  .node--cu {
    fill: color-mix(in srgb, var(--md-sys-color-primary-container) 42%, var(--md-sys-color-background));
  }

  .node--cpu {
    fill: color-mix(in srgb, var(--md-sys-color-surface-variant) 18%, transparent);
    stroke: color-mix(in srgb, var(--md-sys-color-outline) 26%, transparent);
    stroke-width: 1.4;
  }

  .label text {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 20px;
    font-weight: 650;
    fill: var(--md-sys-color-on-surface);
    dominant-baseline: middle;
  }

  .data path {
    fill: none;
    stroke: var(--md-sys-color-on-surface);
    stroke-opacity: 0.78;
    stroke-width: 3.4;
    stroke-linecap: round;
  }

  .control path {
    fill: none;
    stroke: var(--md-sys-color-primary);
    stroke-opacity: 0.95;
    stroke-width: 3.2;
    stroke-linecap: round;
  }

  .status path {
    fill: none;
    stroke: var(--md-sys-color-outline);
    stroke-opacity: 0.9;
    stroke-width: 2.6;
    stroke-linecap: round;
    stroke-dasharray: 8 7;
  }

  .legend rect {
    fill: color-mix(in srgb, var(--md-sys-color-surface-variant) 24%, transparent);
    stroke: color-mix(in srgb, var(--md-sys-color-outline) 18%, transparent);
  }

  .legend text {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 16px;
    font-weight: 560;
    fill: var(--md-sys-color-on-surface-variant);
    dominant-baseline: middle;
  }

  .legend-data,
  .legend-control,
  .legend-status {
    fill: none;
    stroke-linecap: round;
    stroke-width: 3.2;
  }

  .legend-data {
    stroke: var(--md-sys-color-on-surface);
    stroke-opacity: 0.78;
  }

  .legend-control {
    stroke: var(--md-sys-color-primary);
    stroke-opacity: 0.95;
  }

  .legend-status {
    stroke: var(--md-sys-color-outline);
    stroke-opacity: 0.9;
    stroke-dasharray: 8 7;
    stroke-width: 2.6;
  }

  .von-diagram__caption {
    margin-top: 0.85rem;
    color: var(--md-sys-color-on-surface-variant);
    font-size: 0.95rem;
    line-height: 1.55;
  }
</style>
